// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  student
  parent
  teacher
  admin
}

enum NoticePriority {
  normal
  important
  urgent
}

enum ExamType {
  assignment
  quiz
  mid_semester
  end_semester
  practical
}

enum AttendanceStatus {
  present
  absent
  late
  excused
}

enum FeeStatus {
  pending
  partial
  paid
}

enum ParentRequestStatus {
  pending
  approved
  rejected
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(student)
  phone         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]

  studentProfile  StudentProfile?
  teacherProfile  TeacherProfile?
  parentLinks     ParentStudentLink[] @relation("ParentLinks")
  childLinks      ParentStudentLink[] @relation("ChildLinks")
  parentRequests  ParentRequest[]     @relation("ParentRequests")
  authoredNotices Notice[]
  noticeRecipients NoticeRecipient[]
  
  attendance      Attendance[]
  internalMarks   InternalMarks[]
  assignmentSubmissions AssignmentSubmission[]
  feeRecords      FeeRecord[]

  @@index([role])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Department {
  id          String    @id @default(cuid())
  name        String
  code        String    @unique
  description String?
  createdAt   DateTime  @default(now())

  teacherProfiles TeacherProfile[]
  studentProfiles StudentProfile[]
  subjects        Subject[]
  teachingAssignments TeachingAssignment[]
  sections        Section[]

  @@map("departments")
}

model AcademicYear {
  id          String    @id @default(cuid())
  name        String    @unique // e.g. "2026-27"
  startDate   DateTime
  endDate     DateTime
  isCurrent   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  teachingAssignments TeachingAssignment[]
  feeRecords          FeeRecord[]

  @@map("academic_years")
}

model Section {
  id          String    @id @default(cuid())
  name        String    @unique // e.g. "A", "B"
  createdAt   DateTime  @default(now())
  
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  semester     Int?

  studentProfiles StudentProfile[]
  teachingAssignments TeachingAssignment[]

  @@map("sections")
}

model Subject {
  id          String    @id @default(cuid())
  name        String
  code        String    @unique
  creditHours Int       @default(3)
  description String?
  createdAt   DateTime  @default(now())
  
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  teachingAssignments TeachingAssignment[]

  @@map("subjects")
}

model StudentProfile {
  userId          String   @id
  rollNumber      String   @unique
  departmentId    String
  semester        Int
  sectionId       String
  admissionYear   Int?
  createdAt       DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id])
  section    Section    @relation(fields: [sectionId], references: [id])

  @@map("student_profiles")
}

model TeacherProfile {
  userId         String   @id
  employeeNumber String   @unique
  departmentId   String?
  designation    String?
  createdAt      DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])

  teachingAssignments TeachingAssignment[]

  @@map("teacher_profiles")
}

model ParentStudentLink {
  id           String   @id @default(cuid())
  parentId     String
  studentId    String
  relationship String
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())

  parent  User @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  student User @relation("ChildLinks", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@map("parent_student_links")
}

model ParentRequest {
  id                String   @id @default(cuid())
  parentId          String
  parentName        String
  parentEmail       String   @unique
  studentRollNumber String
  relationship      String
  status            ParentRequestStatus @default(pending)
  createdAt         DateTime @default(now())
  reviewedAt        DateTime?

  parent User @relation("ParentRequests", fields: [parentId], references: [id], onDelete: Cascade)

  @@map("parent_requests")
}

model TeachingAssignment {
  id               String   @id @default(cuid())
  teacherProfileId String
  subjectId        String
  departmentId     String
  semester         Int
  sectionId        String
  academicYearId   String
  createdAt        DateTime @default(now())

  teacher      TeacherProfile @relation(fields: [teacherProfileId], references: [userId], onDelete: Cascade)
  subject      Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  department   Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  section      Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  attendance   Attendance[]
  internalMarks InternalMarks[]
  assignments   Assignment[]
  studyMaterials StudyMaterial[]
  timetableSlots TimetableSlot[]

  @@unique([teacherProfileId, subjectId, departmentId, semester, sectionId, academicYearId])
  @@map("teaching_assignments")
}

model Attendance {
  id                   String   @id @default(cuid())
  teachingAssignmentId String
  studentId            String
  date                 DateTime @db.Date
  status               AttendanceStatus
  createdAt            DateTime @default(now())

  teachingAssignment TeachingAssignment @relation(fields: [teachingAssignmentId], references: [id], onDelete: Cascade)
  student            User               @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([teachingAssignmentId, studentId, date])
  @@map("attendance")
}

model InternalMarks {
  id                   String   @id @default(cuid())
  teachingAssignmentId String
  studentId            String
  examType             ExamType
  title                String
  maxMarks             Float
  marksObtained        Float
  createdAt            DateTime @default(now())

  teachingAssignment TeachingAssignment @relation(fields: [teachingAssignmentId], references: [id], onDelete: Cascade)
  student            User               @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("internal_marks")
}

model Assignment {
  id                   String   @id @default(cuid())
  teachingAssignmentId String
  title                String
  description          String   @db.Text
  dueDate              DateTime
  totalMarks           Float
  createdAt            DateTime @default(now())

  teachingAssignment TeachingAssignment @relation(fields: [teachingAssignmentId], references: [id], onDelete: Cascade)
  submissions        AssignmentSubmission[]

  @@map("assignments")
}

model AssignmentSubmission {
  id           String   @id @default(cuid())
  assignmentId String
  studentId    String
  text         String?  @db.Text
  fileUrl      String?
  submittedAt  DateTime @default(now())
  marks        Float?
  feedback     String?  @db.Text

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@map("assignment_submissions")
}

model StudyMaterial {
  id                   String   @id @default(cuid())
  teachingAssignmentId String
  title                String
  description          String?  @db.Text
  fileUrl              String
  uploadedAt           DateTime @default(now())

  teachingAssignment TeachingAssignment @relation(fields: [teachingAssignmentId], references: [id], onDelete: Cascade)

  @@map("study_materials")
}

model TimetableSlot {
  id                   String   @id @default(cuid())
  teachingAssignmentId String
  dayOfWeek            String   // 'monday', 'tuesday', etc.
  startTime            String   // '09:00'
  endTime              String   // '10:00'
  room                 String?

  teachingAssignment TeachingAssignment @relation(fields: [teachingAssignmentId], references: [id], onDelete: Cascade)

  @@map("timetable_slots")
}

model FeeRecord {
  id             String   @id @default(cuid())
  studentId      String
  academicYearId String
  feeType        String   // 'Tuition', 'Hostel', etc.
  description    String?
  amount         Float
  paidAmount     Float    @default(0)
  dueDate        DateTime @db.Date
  status         FeeStatus @default(pending)
  createdAt      DateTime @default(now())

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  student      User         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("fee_records")
}

model Notice {
  id          String         @id @default(cuid())
  authorId    String
  title       String
  content     String         @db.Text
  priority    NoticePriority @default(normal)
  publishedAt DateTime?
  expiresAt   DateTime?
  isPinned    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  author     User              @relation(fields: [authorId], references: [id])
  recipients NoticeRecipient[]

  @@index([publishedAt(sort: Desc)])
  @@map("notices")
}

model NoticeRecipient {
  id         String    @id @default(cuid())
  noticeId   String
  recipientId String
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  notice    Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  recipient User   @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([noticeId, recipientId])
  @@index([recipientId])
  @@map("notice_recipients")
}
